################################
### Deploy Everest Helm chart ##
################################

# Build helm dependencies.
# helm_remote_deps_present() is a fast file-existence check used as a synchronous guard
# below — it ensures helm() can render the chart during Tiltfile evaluation without any
# network calls when .tgz files are already cached.
# read_yaml() also causes Tiltfile to watch Chart.lock files, so a version bump triggers
# a reload and the guard re-runs, fetching the new versions if needed.
def helm_remote_deps_present(chart_dir):
    lock_file = '{0}/Chart.lock'.format(chart_dir)
    if not os.path.exists(lock_file):
        return False
    lock = read_yaml(lock_file)
    if not lock:
        return False
    for dep in lock.get('dependencies', []):
        if dep.get('repository', '').startswith('file://'):
            continue  # local file dep, no .tgz needed
        tgz = '{0}/charts/{1}-{2}.tgz'.format(chart_dir, dep['name'], dep['version'])
        if not os.path.exists(tgz):
            print('Missing helm dep, will run make deps: {0}'.format(tgz))
            return False
    # Check pmm3 subchart (has its own remote dependency)
    pmm3_lock_file = '{0}/charts/pmm3/Chart.lock'.format(chart_dir)
    if os.path.exists(pmm3_lock_file):
        pmm3_lock = read_yaml(pmm3_lock_file)
        if pmm3_lock:
            for dep in pmm3_lock.get('dependencies', []):
                if dep.get('repository', '').startswith('file://'):
                    continue
                tgz = '{0}/charts/pmm3/charts/{1}-{2}.tgz'.format(chart_dir, dep['name'], dep['version'])
                if not os.path.exists(tgz):
                    print('Missing helm dep, will run make deps: {0}'.format(tgz))
                    return False
    return True

# Synchronous guard: runs 'make deps' only when .tgz files are missing (first clone,
# or after a Chart.lock version bump). Required because helm() below renders the chart
# synchronously during Tiltfile evaluation — before any local_resource() has run.
if not helm_remote_deps_present(everest_chart_dir):
    local(
        'HELM="go tool -modfile={0}/go.mod helm" make -C {1} deps'.format(
            backend_dir, everest_chart_dir,
        ),
    )

# Named resource: visible in the Tilt dashboard and usable as a dependency for other
# resources. Uses 'helm dependency list' (local, no network) to check whether any
# remote dependency .tgz files are missing, then runs 'deps-build' only if needed.
# This correctly handles checking out older versions that may remove .tgz files.
local_resource(
    'helm-deps',
    '''HELM_BIN="go tool -modfile={go_mod} helm"
if $HELM_BIN dependency list "{chart_dir}" | grep -q missing || \
   $HELM_BIN dependency list "{chart_dir}/charts/pmm3" | grep -q missing; then
    HELM="$HELM_BIN" make -C "{chart_dir}" deps-build
else
    echo "Helm deps already up to date, skipping"
fi'''.format(
        chart_dir=everest_chart_dir,
        go_mod=backend_dir + '/go.mod',
    ),
    deps=[
        '{0}/Chart.lock'.format(everest_chart_dir),
        '{0}/charts/pmm3/Chart.lock'.format(everest_chart_dir),
        '{0}/charts/everest-db-namespace/Chart.lock'.format(everest_chart_dir),
    ],
    labels=['everest'],
)


# First apply the CRDs since we will not apply them in the helm chart.
everest_crds = kustomize('%s/config/crd' % operator_dir)
k8s_yaml(everest_crds)

everest_yaml = helm(
    everest_chart_dir,
    name='everest',
    namespace=EVEREST_NAMESPACE,
    skip_crds=True,
    values=['./helm-values/webhook-tls-cert-values.yaml'],
    set=[
        'dbNamespace.enabled=false',
        'operator.init=false',
        'upgrade.preflightChecks=false',
        'olm.install=false',
        'createMonitoringResources=false',
        'monitoring.crds.enabled=true',
        'monitoring.crds.plain=false',
        'monitoring.namespaceOverride={0}'.format(EVEREST_MONITORING_NAMESPACE),
        'server.initialAdminPassword={0}'.format(UI_ADMIN_PASSWORD),
    ],
)
# we don't need the catalog source
everest_catalog_source_yaml, everest_yaml = filter_yaml(everest_yaml, kind='CatalogSource', name='everest-catalog')

# we don't need to run default PodSchedulingPolicies cleanup hook
default_psp_cleanup_yaml, everest_yaml = filter_yaml(everest_yaml, kind='Job', namespace=EVEREST_NAMESPACE)

# Patch Everest Server deployment for running with debugger
def patch_everest_debug(in_yaml):
  if not everest_debug:
    return in_yaml

  print('Patching Everest Server deployment for running with debugger')
  objects = decode_yaml_stream(in_yaml)
  for o in objects:
    if o.get('kind') == 'Deployment' and o.get('metadata').get('name') == 'everest-server':
      o['spec']['template']['spec']['securityContext']= {'runAsNonRoot': False}
      for c in o['spec']['template']['spec']['containers']:
        if c.get('name') == 'everest':
          c['ports'] = [{'containerPort': 8080}, {'containerPort': 40000}]
          # In debugger mode the process may be in paused state, need to avoid pod restart
          c['readinessProbe'] = None
          c['livenessProbe'] = None
          c['resources'] = None
  return encode_yaml_stream(objects)

# Patch Everest Operator deployment for running with debugger
def patch_everest_operator_debug(in_yaml):
  if not everest_operator_debug:
    return in_yaml

  print('Patching Everest operator deployment for running with debugger')
  objects = decode_yaml_stream(in_yaml)
  for o in objects:
    if o.get('kind') == 'Deployment' and o.get('metadata').get('name') == 'everest-operator':
      o['spec']['template']['spec']['securityContext']= {'runAsNonRoot': False}
      for c in o['spec']['template']['spec']['containers']:
        if c.get('name') == 'manager':
          c['ports'] = [{'containerPort': 40001}]
          # Need to disable security context for debugger
          c['securityContext'] = None
          # In debugger mode the process may be in paused state, need to avoid pod restart
          c['readinessProbe'] = None
          c['livenessProbe'] = None
          c['resources'] = None
  return encode_yaml_stream(objects)

# Remap the server and controller Deployments to Tilt-local image names so that
# docker_build_with_restart can set separate entrypoints per workload.
# Both share the same Dockerfile and build context; only the Tilt image
# reference and the restart entrypoint differ.
SERVER_TILT_IMAGE = 'ghcr.io/openeverest/openeverest:tilt-server'
CONTROLLER_TILT_IMAGE = 'ghcr.io/openeverest/openeverest:tilt-controller'
def patch_server_tilt_image(in_yaml):
  objects = decode_yaml_stream(in_yaml)
  for o in objects:
    if o.get('kind') == 'Deployment' and o.get('metadata', {}).get('name') == 'everest-server':
      for c in o['spec']['template']['spec']['containers']:
        if c.get('name') == 'everest':
          c['image'] = SERVER_TILT_IMAGE
  return encode_yaml_stream(objects)

def patch_controller_tilt_image(in_yaml):
  objects = decode_yaml_stream(in_yaml)
  for o in objects:
    if o.get('kind') == 'Deployment' and o.get('metadata', {}).get('name') == 'everest-controller':
      for c in o['spec']['template']['spec']['containers']:
        if c.get('name') == 'manager':
          c['image'] = CONTROLLER_TILT_IMAGE
  return encode_yaml_stream(objects)

everest_yaml=patch_everest_debug(everest_yaml)
everest_yaml=patch_everest_operator_debug(everest_yaml)
everest_yaml=patch_server_tilt_image(everest_yaml)
everest_yaml=patch_controller_tilt_image(everest_yaml)
k8s_yaml(everest_yaml)

